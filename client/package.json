{
  "name": "ticket-stream-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Frontend for Ticket Stream incident management",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier \"**/*.{js,jsx,json,md,css}\" --write",
    "prepare": "husky || true",
    "reset": "rm -rf node_modules package-lock.json && npm cache clean --force && npm install"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@tanstack/react-query": "^5.84.2",
    "@tinymce/tinymce-react": "^6.3.0",
    "bootstrap": "^5.3.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "modern-normalize": "^2.0.0",
    "react": "^19.0.0",
    "react-bootstrap": "^2.10.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.62.0",
    "react-icons": "^5.0.0",
    "react-router-dom": "^7.0.0",
    "react-toastify": "^10.0.0",
    "socket.io-client": "^4.8.3",
    "uuid": "^11.1.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "husky": "^9.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.0.0",
    "prettier": "^3.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
