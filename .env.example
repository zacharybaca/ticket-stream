# =============================================================
# Server environment variables
# Copy this file to server/.env and fill in your values.
# =============================================================

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_me

# ── CORS / Client URLs ────────────────────────────────────────
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP via Nodemailer) ───────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_NAME=Ticket Stream
FROM_EMAIL=noreply@example.com

# ── Incident integrations (optional) ──────────────────────────
SLACK_WEBHOOK_URL=

# ── Cloudinary (optional — for avatar uploads) ────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret
